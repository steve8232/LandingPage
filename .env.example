# Copy to .env.local and fill in real values. Never commit .env.local.

# OpenAI — landing-page content generation
OPENAI_API_KEY=

# ScreenshotOne — URL → screenshot for design analysis
SCREENSHOTONE_ACCESS_KEY=
SCREENSHOTONE_SECRET_KEY=

# Unsplash — stock photo search
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# Supabase — auth + project persistence (Phase 1)
# Public values (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row-Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel — programmatic deployment of generated landing pages (Phase 3)
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# AudienceLab — global API key. On first deploy of a project, the deploy
# route creates a pixel via POST /pixels and injects its install script into
# both the landing page and the thank-you page. Same key for all accounts.
# AUDIENCELAB_API_KEY=

# CallRail — global API key (covers every Company on the account). Used by
# the CallRail company picker on the editor toolbar and by the live tail in
# the Leads dashboard. CALLRAIL_ACCOUNT_ID is optional; when missing it's
# resolved once via GET /v3/a.json and cached per process.
# CALLRAIL_API_KEY=
# CALLRAIL_ACCOUNT_ID=

# Heatmap snapshot capture — shared secret protecting /api/internal/snapshot,
# which is called fire-and-forget by the deployments route when a build
# reaches status='ready'. Set to any long random string. Leave unset to
# disable snapshot capture entirely (heatmaps still ingest events, just
# without a frozen background image).
# INTERNAL_SNAPSHOT_SECRET=

# RBAC — comma-separated list of admin emails. On first sign-in, any user
# whose email matches (case-insensitive) is promoted to role='admin' via the
# service-role client. Admins can create new SparkPages, delete projects,
# and manage collaborators. All other users default to role='user' (view +
# edit only on projects they own or are invited to).
# SPARKPAGE_ADMIN_EMAILS=you@example.com,team@example.com
